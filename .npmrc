# =====================================================================
# サプライチェーン攻撃対策 .npmrc 設定
# =====================================================================

# ■ インストール時のスクリプトを自動実行しない (必須級の対策)
# パッケージに含まれる `preinstall` や `postinstall` などのスクリプトの自動実行を無効化します。
# これにより、パッケージインストール時に悪意のあるコードが実行されるのを強力に防ぎます。
# ※スクリプト実行が必須のパッケージを利用する場合は、個別に `npm run` 等で対応する必要があります。
ignore-scripts=true

# ■ 脆弱性が高いものはインストールしない（警告レベルの設定）
# `npm audit` による脆弱性チェックの閾値を設定します。
# `high` に設定することで、High または Critical の脆弱性がある場合に警告を出します。
# ※【重要】: npm標準機能では、これだけで `npm install` の処理自体を完全にブロックすることはできません。
# 確実にインストールを止めるには、CI/CDパイプライン等で `npm install` の後に `npm audit --audit-level=high` を実行し、その終了コード(失敗)でパイプラインを停止させる運用が必要です。
audit-level=high

# ■ 公開されてから7日間経過したものをインストールする
# 公開直後のパッケージは、脆弱性や悪意のあるコードが含まれていてもコミュニティに発見されていない（ゼロデイに近い）状態であるリスクが高いです。
# 7日間の「エイジング期間」を設けることで、脆弱性のあるライブラリ公開直後のインストールを防止します。
min-release-age=7

# ■ パッケージのバージョンを厳密に固定する (キャレット ^ や チルダ ~ を使わない)
# `npm install <package>` を実行した際、`package.json` にバージョンを完全固定（例: `"package": "1.2.3"`）して保存します。
# 意図しない自動マイナーアップデートを防ぎ、検証済みのバージョンのみを使用することで、アップデートに紛れ込んだ不正なコードの混入リスクを下げます。
# save-exact=true わざとコメントアウト

# ■ 使用するレジストリを公式に固定する
# 意図せず別のサードパーティレジストリからパッケージをダウンロードしてしまうのを防ぎます。
registry=https://registry.npmjs.org/

# ■ パッケージ作者への寄付を促すメッセージを非表示にする (運用向け)
# セキュリティには直接関係ありませんが、ターミナルやCIのログをクリーンに保ち、重要な警告を見落とさないようにするために有用です。
fund=false